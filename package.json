{
  "name": "azdopr-simple",
  "displayName": "Azure DevOps PR Viewer (Simple)",
  "description": "View all Pull Requests across your Azure DevOps organization — simple and focused",
  "version": "0.1.0",
  "author": "JoaoVictorLong",
  "publisher": "joaovictorlong",
  "license": "MIT",
  "repository": "https://github.com/JoaoVictorLong/azdopr-vs-extention",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onView:azureDevOpsPRs",
    "onCommand:azureDevOpsPRs.refresh",
    "onCommand:azureDevOpsPRs.signIn",
    "onCommand:azureDevOpsPRs.signOut",
    "onCommand:azureDevOpsPRs.openPR",
    "onCommand:azureDevOpsPRs.viewPR"
  ],
  "contributes": {
    "commands": [
      {
        "command": "azureDevOpsPRs.refresh",
        "title": "Refresh Pull Requests",
        "category": "Azure DevOps PR Viewer",
        "icon": "$(refresh)"
      },
      {
        "command": "azureDevOpsPRs.signIn",
        "title": "Sign In",
        "category": "Azure DevOps PR Viewer",
        "icon": "$(sign-in)"
      },
      {
        "command": "azureDevOpsPRs.signOut",
        "title": "Sign Out",
        "category": "Azure DevOps PR Viewer",
        "icon": "$(sign-out)"
      },
      {
        "command": "azureDevOpsPRs.openPR",
        "title": "Open Pull Request in Browser",
        "category": "Azure DevOps PR Viewer"
      },
      {
        "command": "azureDevOpsPRs.viewPR",
        "title": "View Pull Request Details",
        "category": "Azure DevOps PR Viewer"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "azure-devops-pr-explorer",
          "title": "Azure DevOps PR Viewer",
          "icon": "resources/azdopr-icon.png"
        }
      ]
    },
    "views": {
      "azure-devops-pr-explorer": [
        {
          "icon": "resources/azdopr-icon.png",
          "id": "azureDevOpsPRs",
          "name": "Pull Requests"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "azureDevOpsPRs.refresh",
          "when": "view == azureDevOpsPRs",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "azureDevOpsPRs.openPR",
          "when": "view == azureDevOpsPRs && viewItem == pullrequest",
          "group": "inline@1"
        },
        {
          "command": "azureDevOpsPRs.viewPR",
          "when": "view == azureDevOpsPRs && viewItem == pullrequest",
          "group": "inline@2"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "azureDevOpsPRs",
        "contents": "Welcome to Azure DevOps PR Viewer!\n\nTo get started, set the **azureDevOpsPRViewer.organization** and **azureDevOpsPRViewer.patToken** settings.\n\n[Sign In](command:azureDevOpsPRs.signIn)\n\nOnce authenticated, you'll see all pull requests from your organization.",
        "when": "!azureDevOpsPRs:authenticated"
      }
    ],
    "configuration": {
      "title": "Azure DevOps PR Viewer",
      "properties": {
        "azureDevOpsPRViewer.organization": {
          "type": "string",
          "default": "",
          "description": "Azure DevOps organization name (e.g., 'myorg' from dev.azure.com/myorg)"
        },
        "azureDevOpsPRViewer.patToken": {
          "type": "string",
          "default": "",
          "description": "Personal Access Token (PAT) for Azure DevOps authentication"
        },
        "azureDevOpsPRViewer.maxPRsToFetch": {
          "type": "number",
          "default": 200,
          "description": "Maximum number of PRs to fetch"
        },
        "azureDevOpsPRViewer.autoRefreshInterval": {
          "type": "number",
          "default": 300,
          "description": "Auto-refresh interval in seconds (0 to disable)"
        }
      }
    }
  },
  "scripts": {
    "compile": "vite build",
    "watch": "vite build --watch",
    "package": "vite build --mode production",
    "vscode:prepublish": "vite build",
    "package:vsix": "vsce package"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.105.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.2",
    "vite-plugin-static-copy": "^4.1.1"
  },
  "dependencies": {
    "axios": "^1.13.2"
  }
}
